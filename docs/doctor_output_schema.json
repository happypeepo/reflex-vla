{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://reflex-vla.io/schemas/doctor-output-v1.json",
  "title": "reflex doctor --format json output",
  "description": "Stable envelope for `reflex doctor --format json`. Schema v1: additive fields don't bump version; breaking changes do. Authoritative spec for CI consumers.",
  "type": "object",
  "required": ["schema_version", "timestamp", "model", "embodiment", "checks", "summary"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 UTC, ms precision, trailing Z"
    },
    "model": {
      "type": "string",
      "description": "Path passed via --model (empty if doctor ran in system-probe-only mode)"
    },
    "embodiment": {
      "type": "string",
      "description": "Embodiment preset name passed via --embodiment (or 'custom')"
    },
    "checks": {
      "type": "array",
      "items": { "$ref": "#/definitions/CheckResult" }
    },
    "summary": {
      "type": "object",
      "required": ["pass", "fail", "warn", "skip"],
      "additionalProperties": false,
      "properties": {
        "pass": { "type": "integer", "minimum": 0 },
        "fail": { "type": "integer", "minimum": 0 },
        "warn": { "type": "integer", "minimum": 0 },
        "skip": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "definitions": {
    "CheckResult": {
      "type": "object",
      "required": [
        "check_id", "name", "status",
        "expected", "actual", "remediation", "duration_ms"
      ],
      "additionalProperties": false,
      "properties": {
        "check_id": {
          "type": "string",
          "pattern": "^check_[a-z_]+$",
          "description": "Stable ID, e.g. check_model_load"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable name (e.g. 'Model load')"
        },
        "status": {
          "type": "string",
          "enum": ["pass", "fail", "warn", "skip"]
        },
        "expected": {
          "type": "string",
          "description": "What the check wanted to see"
        },
        "actual": {
          "type": "string",
          "description": "What it actually saw"
        },
        "remediation": {
          "type": "string",
          "description": "Fix-it suggestion. Required when status=fail (enforced at runtime); empty otherwise."
        },
        "duration_ms": {
          "type": "number",
          "minimum": 0
        },
        "github_issue": {
          "type": ["string", "null"],
          "format": "uri",
          "description": "URL to the load-bearing LeRobot issue (or null)"
        }
      }
    }
  }
}
